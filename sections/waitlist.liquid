<section class="vcsc-waitlist" id="waitlist">
  <div class="vcsc-waitlist__bg-pattern" aria-hidden="true"></div>
  <div class="vcsc-container vcsc-waitlist__inner">

    <div class="vcsc-waitlist__content">
      <p class="vcsc-section-eyebrow vcsc-section-eyebrow--light">Pre-Order Access</p>
      <h2 class="vcsc-waitlist__title">You're Almost<br>Out of Control</h2>
      <p class="vcsc-waitlist__sub">
        Be the first to know when we ship. No spam. Just one email.
        Much like this button, we respect your boundaries exactly once.
      </p>
    </div>

    <div class="vcsc-waitlist__form-wrap">
      {% form 'customer', class: 'vcsc-waitlist__form' %}
        {{ form.errors | default_errors }}
        <input type="hidden" name="contact[tags]" value="waitlist,approve-button-preorder">

        <div class="vcsc-waitlist__input-group">
          <input
            type="email"
            name="contact[email]"
            id="waitlist-email"
            class="vcsc-input"
            placeholder="your@email.com"
            required
            autocomplete="email"
          >
          <button type="submit" class="vcsc-btn vcsc-btn--primary vcsc-btn--waitlist">
            Reserve My Surrender Device
          </button>
        </div>

        {% if form.posted_successfully? %}
          <div class="vcsc-waitlist__success" role="alert">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            You're on the list. We'll be in touch before the next production incident.
          </div>
        {% endif %}

        <p class="vcsc-waitlist__legal">
          By signing up you agree to nothing legally binding. Probably.
        </p>
      {% endform %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Waitlist",
  "settings": []
}
{% endschema %}

<section class="vcsc-press">
  <div class="vcsc-container">
    <p class="vcsc-press__eyebrow">As Seen In</p>
    <div class="vcsc-press__logos">
      <div class="vcsc-press__logo-item">
        <span class="vcsc-press__logo-text">My Mom's Basement Quarterly</span>
      </div>
      <div class="vcsc-press__logo-item">
        <span class="vcsc-press__logo-text">Hacker News <span class="vcsc-press__qualifier">(Flagged)</span></span>
      </div>
      <div class="vcsc-press__logo-item">
        <span class="vcsc-press__logo-text">TechCrunch <span class="vcsc-press__qualifier">(Unverified)</span></span>
      </div>
      <div class="vcsc-press__logo-item">
        <span class="vcsc-press__logo-text">The Changelog <span class="vcsc-press__qualifier">(We Think)</span></span>
      </div>
      <div class="vcsc-press__logo-item">
        <span class="vcsc-press__logo-text">Forbes <span class="vcsc-press__qualifier">(Not Forbes)</span></span>
      </div>
    </div>
  </div>
</section>


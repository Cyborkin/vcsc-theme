<section class="vcsc-hero" id="hero">
  <div class="vcsc-hero__bg-grid"></div>

  <div class="vcsc-container vcsc-hero__inner">
    <div class="vcsc-hero__content">
      <div class="vcsc-hero__badge">
        <span class="vcsc-badge-dot"></span>
        Enterprise Edition — Now Available for Pre-Order
      </div>

      <h1 class="vcsc-hero__headline">
        Stop Thinking.<br>Start Approving.
      </h1>
      <p class="vcsc-hero__disclaimer"><em>*Not a real keyboard</em></p>

      <p class="vcsc-hero__subheadline">
        The world's first enterprise-grade, one-touch AI output ratification device.
        Designed for the developer who has seen the code, chosen not to read it,
        and pressed Approved anyway.
      </p>

      <div class="vcsc-hero__actions">
        <a href="#waitlist" class="vcsc-btn vcsc-btn--primary">
          Reserve Your Autonomy Surrender Device
          <span class="vcsc-btn-arrow">→</span>
        </a>
        <a href="#product" class="vcsc-btn vcsc-btn--ghost">View Specifications</a>
      </div>

      <div class="vcsc-hero__trust">
        <span class="vcsc-trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Ships when ready
        </span>
        <span class="vcsc-trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Lifetime warranty*
        </span>
        <span class="vcsc-trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Zero accountability included
        </span>
      </div>
    </div>

    <div class="vcsc-hero__visual">
      <div class="vcsc-hero__img-wrap">
        <img
          src="{{ 'hero.png' | asset_url }}"
          alt="The Approve Button — enterprise-grade AI ratification device with blue LED glow"
          class="vcsc-hero__img"
          width="600"
          height="480"
          loading="eager"
        >
        <div class="vcsc-hero__glow"></div>
      </div>

      <div class="vcsc-demo-button" aria-hidden="true">
        <div class="vcsc-demo-button__key vcsc-demo-button__key--approved">
          <span>APPROVED</span>
        </div>
      </div>
    </div>
  </div>

  <div class="vcsc-hero__scroll">
    <span>Scroll to learn more about your inevitable surrender</span>
    <div class="vcsc-scroll-arrow">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": []
}
{% endschema %}

<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="The world's first enterprise-grade AI output ratification device. Stop Thinking. Start Approving.">
  <title>{{ page_title }} — Vibe Coder Supply Co.</title>

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

  {{ 'vcsc-base.css' | asset_url | stylesheet_tag }}
</head>
<body class="vcsc-body">

  {% section 'header' %}

  <main id="main-content">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {{ 'vcsc-main.js' | asset_url | script_tag }}
</body>
</html>
